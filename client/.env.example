# ── NVIDIA Build (build.nvidia.com) LLM API ──────────────────────────
# 발급: https://build.nvidia.com 에서 모델 카드 → "Get API Key"
# ⚠️ 서버에서만 사용. NEXT_PUBLIC_ 접두사 붙이지 말 것 (브라우저 노출됨)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI 호환 엔드포인트 (기본값이라 안 바꿔도 됨)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 파싱 모델. qwen3-next(MoE)가 정확도-속도 최적(≈2s, 웜 <1s). 미설정 시 코드 기본값과 동일.
# 대안: meta/llama-3.1-70b-instruct(정확·느림) / meta/llama-3.1-8b-instruct(빠름·환각多)
NVIDIA_MODEL=qwen/qwen3-next-80b-a3b-instruct
