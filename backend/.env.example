# backend 데이터 수집 파이프라인 환경변수 (팀 공유용 템플릿)
# 사용법: cp .env.example .env.local  후 실제 값 채우기. .env.local 은 커밋되지 않음.

# ── 네이버 쇼핑 검색 Open API ──────────────────────────────────────
# 발급: https://developers.naver.com/apps/#/register
#   → 애플리케이션 등록 → 사용 API "검색" 선택 → WEB 환경 추가(http://localhost)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── Supabase (적재 대상 DB) ────────────────────────────────────────
# 대시보드 → Project Settings → API Keys → "Secret keys"에서 sb_secret_... 복사.
# 새 키 체계(2025~): secret 키가 과거 service_role 대체. (레거시 service_role도 2026말까지 동작)
# ⚠️ secret 키는 서버 전용(전체 권한). 절대 클라이언트/브라우저/커밋에 노출 금지.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── DB 백업용 접속 문자열 (scripts/backup_db.sh 에서만 사용) ─────────
# 대시보드 → Connect → psql/ORM 의 connection string(세션 풀러 권장).
# <DB비번>은 프로젝트 생성 시 정한 DB 비밀번호(= supabase link 때 입력한 값).
# ⚠️ 비번 포함 — 절대 커밋 금지(.env.local 은 git 무시됨).
SUPABASE_DB_URL=postgresql://postgres.your-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres
